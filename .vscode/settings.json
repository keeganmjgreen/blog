{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "cSpell.words": [
        "Arazzo",
        "ASGI",
        "AUTOINCREMENT",
        "bitrates",
        "bluegreen",
        "chunker",
        "cluedo",
        "daylength",
        "EJSON",
        "Geospacial",
        "HATEOAS",
        "HRLT",
        "hypertables",
        "ipykernel",
        "ipynb",
        "Jeong's",
        "Keegan",
        "Keegan's",
        "Keeganʼs",
        "kubelet",
        "magick",
        "makemigrations",
        "mathbf",
        "mathit",
        "mathrm",
        "microcontroller",
        "minicom",
        "mongosh",
        "mysite",
        "OCPI",
        "OCPP",
        "phasor",
        "phasors",
        "photosensors",
        "pycache",
        "pypsa",
        "reagraph",
        "redirector",
        "Résumé",
        "runserver",
        "SCDM",
        "sqlmigrate",
        "startapp",
        "themself",
        "touchsreen",
        "UART",
        "unreactive",
        "urlpatterns",
        "vantablack",
        "varchar",
        "venv",
        "watchlist",
        "webp",
        "WSGI"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    "editor.formatOnSave": true,
    "files.exclude": {
        "**/__pycache__/": true,
        ".pytest_cache/": true,
        ".ruff_cache/": true
    },
    "files.trimTrailingWhitespace": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.typeCheckingMode": "strict"
}